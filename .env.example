# ============================================================================
# 3A Studio — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
# All values marked [required] must be set for production.
# ============================================================================

# --- Database ---
# Prisma connection URL (PostgreSQL / Neon)
DATABASE_URL=[required]
# Direct connection (for migrations)
DIRECT_URL=[required]

# --- Auth ---
# JWT signing secret (random 64-char hex string)
AUTH_SECRET=[required]
# Admin credentials (demo mode — replaced by DB users in Phase 4)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# --- API Key Encryption ---
# AES-256-GCM encryption key (64-char hex string = 32 bytes)
ENCRYPTION_KEY=[required]

# --- LLM Providers (Z.ai SDK) ---
ZAI_API_KEY=
ZAI_BASE_URL=
ZAI_MODEL=

# --- Vercel (auto-set by Vercel) ---
# VERCEL_URL=
# VERCEL_ENV=
