{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@stsgs/ui": ["./packages/ui/src"],
      "@stsgs/ui/*": ["./packages/ui/src/*"],
      "@stsgs/shared": ["./packages/shared/src"],
      "@stsgs/shared/*": ["./packages/shared/src/*"],
      "@stsgs/prompting": ["./packages/prompting/src"],
      "@stsgs/prompting/*": ["./packages/prompting/src/*"]
    }
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", "packages/**/*.ts", "packages/**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "packages/*/node_modules", "packages/eslint-plugin", "skills"]
}
