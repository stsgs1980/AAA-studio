    "@radix-ui/react-slot": "^1.1.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@xyflow/react": "^12.6.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.4.7",
    "lucide-react": "^0.475.0",
    "next": "^15.3.3",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.55.0",
    "shiki": "^4.1.0",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.0.2",
    "ws": "^8.21.0",
